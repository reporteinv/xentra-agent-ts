# xentra-agent-ts — Variables de entorno
# Copiar este archivo como .env y completar los valores reales
# NUNCA subir el .env real al repositorio

# ─── Servidor ────────────────────────────────────────────────
PORT=                        # Puerto del servidor (ej: 3001)

# ─── Base de datos (MariaDB en Zero 3) ───────────────────────
DB_HOST=                     # IP del servidor MariaDB (ej: 192.168.0.10)
DB_USER=                     # Usuario de base de datos
DB_PASS=                     # Contraseña de base de datos
DB_NAME=                     # Nombre de la base de datos (ej: xentra_pcs_db)

# ─── Sesiones web ────────────────────────────────────────────
SESSION_SECRET=              # Cadena aleatoria larga para firmar cookies de sesión

# ─── Agente PowerShell ───────────────────────────────────────
AGENT_TOKEN=                 # Token que valida cada request del agente PS1

# ─── Alertas WhatsApp (CallMeBot) ────────────────────────────
CALLMEBOT_PHONE=             # Número WhatsApp con código de país (ej: 573001234567)
CALLMEBOT_APIKEY=            # API key de CallMeBot
